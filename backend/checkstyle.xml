<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
    Checkstyle configuration for Car Rental Backend (Spring Boot + Java 17).
    Based on Google Java Style with modifications for Spring Boot conventions.
-->

<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <property name="severity" value="warning"/>
    <property name="fileExtensions" value="java"/>

    <!-- Exclude module-info.java -->
    <module name="BeforeExecutionExclusionFileFilter">
        <property name="fileNamePattern" value="module\-info\.java$"/>
    </module>

    <!-- Files must end with a newline -->
    <module name="NewlineAtEndOfFile"/>

    <!-- No tabs allowed -->
    <module name="RegexpSingleline">
        <property name="format" value="\t"/>
        <property name="message" value="Табуляция не допускается. Используйте пробелы."/>
    </module>

    <!-- Line length: 140 for readability in Spring Boot projects -->
    <module name="FileLength">
        <property name="max" value="1000"/>
    </module>

    <module name="TreeWalker">
        <!-- Imports -->
        <module name="UnusedImports"/>
        <module name="RedundantImport"/>
        <module name="IllegalImport"/>
        <module name="AvoidStarImport"/>

        <!-- Naming conventions -->
        <module name="LocalVariableName"/>
        <module name="MemberName"/>
        <module name="MethodName"/>
        <module name="PackageName"/>
        <module name="ParameterName"/>
        <module name="TypeName"/>
        <module name="ConstantName"/>
        <module name="StaticVariableName"/>
        <module name="ClassTypeParameterName"/>

        <!-- Code structure -->
        <module name="ModifierOrder"/>
        <module name="RedundantModifier"/>
        <module name="EmptyBlock"/>
        <module name="LeftCurly"/>
        <module name="RightCurly"/>
        <module name="NeedBraces"/>

        <!-- Metrics -->
        <module name="MethodLength">
            <property name="max" value="80"/>
            <property name="countEmpty" value="false"/>
        </module>
        <module name="ParameterNumber">
            <property name="max" value="10"/>
        </module>

        <!-- Missing Javadoc for public methods is a warning -->
        <module name="MissingJavadocMethod">
            <property name="severity" value="info"/>
            <property name="minLineCount" value="15"/>
            <property name="allowedAnnotations" value="Override,Test,Bean,Autowired,Value,Qualifier"/>
            <property name="scope" value="public"/>
        </module>

        <!-- Comments -->
        <module name="JavadocStyle">
            <property name="severity" value="info"/>
            <property name="checkFirstSentence" value="false"/>
        </module>

        <!-- No System.out.println -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="System\.out\.println"/>
            <property name="message" value="Используйте Logger вместо System.out.println()"/>
            <property name="ignoreComments" value="true"/>
        </module>

        <!-- Class data abstraction coupling -->
        <module name="ClassDataAbstractionCoupling">
            <property name="max" value="15"/>
        </module>
    </module>
</module>
